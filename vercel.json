{
  "version": 2,
  "name": "skysure-unified",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/frontend/dist/index.html"
    },
    {
      "source": "/rider/(.*)",
      "destination": "/frontend/dist/index.html"
    },
    {
      "source": "/login",
      "destination": "/frontend/dist/index.html"
    },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}